@page "/factorial"
@rendermode InteractiveServer

<PageTitle>Factorial</PageTitle>

<h3>Factorial</h3>

<div class="factorial">
	<input type="number" min="0" @bind="number" @bind:after="Calculate" />
	<div id="factorial"> @factorial </div>

</div>
<ol>
	@{
		foreach (long i in results)
		{
			<li>@i</li>
		}
	}
</ol>

@code {
	int number;
	long factorial = 1;
	List<long> results = new List<long>();
	void setNumber(int number)
	{
		this.number = number;
	}
	void Calculate()
	{
		factorial = 1;
		results = new List<long>();
		for (int i = 1; i <= number; i++)
		{
			factorial *= i;
			results.Add(factorial);
		}
	}
}
